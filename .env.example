# RarePlaylistAI Environment Variables

# Hi-Fi API Configuration
HIFI_API_BASE_URL=https://api.monochrome.tf
HIFI_API_KEY=your_api_key_here

# Groq LLM (free tier - get key from https://console.groq.com)
